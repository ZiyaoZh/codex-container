#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
Usage:
  codex-container [options] [command...]

Options:
  --agent codex|claude   Start the selected coding agent. Defaults to codex.
  --update               Rebuild the image and install the latest Codex CLI.
  --repo PATH            Mount PATH as the workspace. Defaults to the current directory.
  --image IMAGE          Docker image to run. Defaults to codex-universal:latest.
  --name NAME            Container name. Defaults to codex-<repo-name>.
  --home PATH            Persistent container home. Defaults to ~/.cache/codex-container/home.
  --docker               Require Docker access through the host Docker socket.
  --no-docker            Do not mount the host Docker socket.
  --no-ssh               Do not mount ~/.ssh.
  --no-gitconfig         Do not mount ~/.gitconfig.
  -h, --help             Show this help.

Examples:
  codex-container
  codex-container --update
  codex-container --agent claude
  codex-container --docker
  codex-container bash
  codex-container --repo /path/to/repo --agent claude
  CODEX_IMAGE=my-codex:dev codex-container
EOF
}

IMAGE="${CODEX_IMAGE:-codex-universal:latest}"
REPO_DIR="${CODEX_REPO_DIR:-$PWD}"
AGENT="${CODEX_AGENT:-codex}"
CONTAINER_NAME="${CODEX_CONTAINER_NAME:-}"
MOUNT_DOCKER="${CODEX_MOUNT_DOCKER:-auto}"
MOUNT_SSH=1
MOUNT_GITCONFIG=1
CONTAINER_HOME="${CODEX_CONTAINER_HOME:-}"
UPDATE_IMAGE=0

command_args=()

while [[ "$#" -gt 0 ]]; do
  case "$1" in
    --agent)
      [[ "$#" -ge 2 ]] || { echo "Missing value for --agent" >&2; exit 2; }
      AGENT="$2"
      shift 2
      ;;
    --update)
      UPDATE_IMAGE=1
      shift
      ;;
    --repo)
      [[ "$#" -ge 2 ]] || { echo "Missing value for --repo" >&2; exit 2; }
      REPO_DIR="$2"
      shift 2
      ;;
    --image)
      [[ "$#" -ge 2 ]] || { echo "Missing value for --image" >&2; exit 2; }
      IMAGE="$2"
      shift 2
      ;;
    --name)
      [[ "$#" -ge 2 ]] || { echo "Missing value for --name" >&2; exit 2; }
      CONTAINER_NAME="$2"
      shift 2
      ;;
    --home)
      [[ "$#" -ge 2 ]] || { echo "Missing value for --home" >&2; exit 2; }
      CONTAINER_HOME="$2"
      shift 2
      ;;
    --docker)
      MOUNT_DOCKER=1
      shift
      ;;
    --no-docker)
      MOUNT_DOCKER=0
      shift
      ;;
    --no-ssh)
      MOUNT_SSH=0
      shift
      ;;
    --no-gitconfig)
      MOUNT_GITCONFIG=0
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    --)
      shift
      command_args+=("$@")
      break
      ;;
    *)
      command_args+=("$@")
      break
      ;;
  esac
done

case "$MOUNT_DOCKER" in
  auto|0|1) ;;
  *)
    echo "Invalid CODEX_MOUNT_DOCKER value: $MOUNT_DOCKER" >&2
    echo "Expected: auto, 0, or 1" >&2
    exit 2
    ;;
esac

DOCKER_REQUEST="$MOUNT_DOCKER"

if [[ "$UPDATE_IMAGE" == "1" ]]; then
  if [[ "${#command_args[@]}" -gt 0 ]]; then
    echo "--update cannot be combined with a container command." >&2
    exit 2
  fi

  SCRIPT_PATH="$(readlink -f "${BASH_SOURCE[0]}")"
  BUILD_CONTEXT="$(dirname "$SCRIPT_PATH")"

  echo "Updating Codex CLI in image: $IMAGE"
  exec docker build \
    --build-arg "CODEX_CACHE_BUST=$(date +%s)" \
    --build-arg "CODEX_VERSION=latest" \
    -t "$IMAGE" \
    "$BUILD_CONTEXT"
fi

case "$AGENT" in
  codex|claude) ;;
  *)
    echo "Unsupported agent: $AGENT" >&2
    echo "Expected: codex or claude" >&2
    exit 2
    ;;
esac

if [[ ! -d "$REPO_DIR" ]]; then
  echo "Repo directory does not exist: $REPO_DIR" >&2
  exit 1
fi

REPO_DIR="$(cd "$REPO_DIR" && pwd)"
REPO_BASENAME="$(basename "$REPO_DIR")"
REPO_NAME="$(printf '%s' "$REPO_BASENAME" | tr -c 'a-zA-Z0-9_.-' '-')"
CONTAINER_NAME="${CONTAINER_NAME:-codex-${REPO_NAME}}"
DEFAULT_CONTAINER_WORKDIR="/workspace/repo"
CONTAINER_WORKDIR="$DEFAULT_CONTAINER_WORKDIR"
CACHE_ROOT="${CODEX_CACHE_ROOT:-$HOME/.cache/codex-container}"
CONTAINER_HOME="${CONTAINER_HOME:-$CACHE_ROOT/home}"
DOCKER_MODE="none"

if [[ "$MOUNT_DOCKER" == "auto" ]]; then
  if [[ -S /var/run/docker.sock ]]; then
    MOUNT_DOCKER=1
  else
    MOUNT_DOCKER=0
  fi
fi

if [[ "$MOUNT_DOCKER" == "1" ]]; then
  CONTAINER_WORKDIR="$REPO_DIR"
  DOCKER_MODE="socket"
fi

if [[ "${#command_args[@]}" -gt 0 ]]; then
  container_command=("${command_args[@]}")
else
  container_command=("$AGENT")
fi

if container_running="$(docker inspect --format '{{.State.Running}}' "$CONTAINER_NAME" 2>/dev/null)"; then
  if [[ "$container_running" != "true" ]]; then
    echo "Container exists but is not running: $CONTAINER_NAME" >&2
    echo "Remove it with: docker rm $CONTAINER_NAME" >&2
    exit 1
  fi

  existing_repo="$(docker inspect \
    --format '{{with index .Config.Labels "dev.codex-container.repo"}}{{.}}{{end}}' \
    "$CONTAINER_NAME")"
  if [[ -n "$existing_repo" && "$existing_repo" != "$REPO_DIR" ]]; then
    echo "Container name is already used for another repository: $CONTAINER_NAME" >&2
    echo "Existing repository: $existing_repo" >&2
    echo "Requested repository: $REPO_DIR" >&2
    exit 1
  fi

  existing_workdir="$(docker inspect \
    --format '{{with index .Config.Labels "dev.codex-container.workdir"}}{{.}}{{end}}' \
    "$CONTAINER_NAME")"
  if [[ -n "$existing_workdir" ]]; then
    CONTAINER_WORKDIR="$existing_workdir"
  else
    CONTAINER_WORKDIR="$DEFAULT_CONTAINER_WORKDIR"
  fi

  existing_docker_socket="$(docker inspect \
    --format '{{range .Mounts}}{{if eq .Destination "/var/run/docker.sock"}}{{.Source}}{{end}}{{end}}' \
    "$CONTAINER_NAME")"

  if [[ "$MOUNT_DOCKER" == "1" ]]; then
    if [[ -z "$existing_docker_socket" ]]; then
      echo "The running container was started without Docker access: $CONTAINER_NAME" >&2
      echo "Exit its active sessions, then start it again with --docker." >&2
      exit 1
    fi
  fi

  if [[ "$DOCKER_REQUEST" == "0" && -n "$existing_docker_socket" ]]; then
    echo "The running container already has Docker access: $CONTAINER_NAME" >&2
    echo "Exit its active sessions, then start it again with --no-docker." >&2
    exit 1
  fi

  echo "Reusing running container: $CONTAINER_NAME" >&2
  exec docker exec \
    -it \
    -e "HOME=/home/codex" \
    -e "TERM=${TERM:-xterm-256color}" \
    -e "COLORTERM=${COLORTERM:-truecolor}" \
    -w "$CONTAINER_WORKDIR" \
    "$CONTAINER_NAME" \
    gosu codex \
    "${container_command[@]}"
fi

docker_args=(
  run
  --rm
  -it
  --name "$CONTAINER_NAME"
  --label "dev.codex-container.repo=$REPO_DIR"
  --label "dev.codex-container.workdir=$CONTAINER_WORKDIR"
  --label "dev.codex-container.docker-mode=$DOCKER_MODE"
  -e "CODEX_UID=$(id -u)"
  -e "CODEX_GID=$(id -g)"
  -e "TERM=${TERM:-xterm-256color}"
  -e "COLORTERM=${COLORTERM:-truecolor}"
  -v "$REPO_DIR:$DEFAULT_CONTAINER_WORKDIR"
  -w "$CONTAINER_WORKDIR"
)

if [[ "$MOUNT_DOCKER" == "1" && "$REPO_DIR" != "$DEFAULT_CONTAINER_WORKDIR" ]]; then
  # The host daemon must see bind-mount paths exactly as the Docker client sends them.
  docker_args+=(-v "$REPO_DIR:$REPO_DIR")
fi

mount_if_exists() {
  local source="$1"
  local target="$2"
  local mode="${3:-}"

  if [[ -e "$source" ]]; then
    if [[ -n "$mode" ]]; then
      docker_args+=(-v "$source:$target:$mode")
    else
      docker_args+=(-v "$source:$target")
    fi
  fi
}

mkdir -p \
  "$HOME/.codex" \
  "$HOME/.claude" \
  "$HOME/.config/gh" \
  "$CACHE_ROOT"/{npm,pip,cargo,go,maven,gradle,cache} \
  "$CONTAINER_HOME/.config"

docker_args+=(
  -v "$CONTAINER_HOME:/home/codex"
  -v "$HOME/.codex:/home/codex/.codex"
  -v "$HOME/.claude:/home/codex/.claude"
  -v "$HOME/.config/gh:/home/codex/.config/gh"
  -v "$CACHE_ROOT/npm:/home/codex/.npm"
  -v "$CACHE_ROOT/pip:/home/codex/.cache/pip"
  -v "$CACHE_ROOT/cargo:/home/codex/.cargo"
  -v "$CACHE_ROOT/go:/home/codex/go"
  -v "$CACHE_ROOT/maven:/home/codex/.m2"
  -v "$CACHE_ROOT/gradle:/home/codex/.gradle"
  -v "$CACHE_ROOT/cache:/cache"
)

if [[ "$MOUNT_SSH" == "1" ]]; then
  mount_if_exists "$HOME/.ssh" "/home/codex/.ssh" "ro"
fi

if [[ "$MOUNT_GITCONFIG" == "1" ]]; then
  mount_if_exists "$HOME/.gitconfig" "/home/codex/.gitconfig" "ro"
fi

mount_if_exists "$HOME/.git-credentials" "/home/codex/.git-credentials" "ro"
mount_if_exists "$HOME/.gnupg" "/home/codex/.gnupg" "ro"
mount_if_exists "$HOME/.claude.json" "/home/codex/.claude.json"

if [[ "$MOUNT_DOCKER" == "1" ]]; then
  if [[ -S /var/run/docker.sock ]]; then
    docker_args+=(-v /var/run/docker.sock:/var/run/docker.sock)
  else
    echo "Docker socket was requested but /var/run/docker.sock does not exist." >&2
    exit 1
  fi
fi

if [[ "$MOUNT_DOCKER" == "1" ]]; then
  docker_args+=(-e "DOCKER_HOST=unix:///var/run/docker.sock")
  mount_if_exists "$HOME/.docker" "/home/codex/.docker"
fi

docker_args+=("$IMAGE")
docker_args+=("${container_command[@]}")

exec docker "${docker_args[@]}"
